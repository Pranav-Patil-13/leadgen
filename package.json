{
  "name": "leadgen",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build:css": "tailwindcss -i ./backend/static/css/input.css -o ./backend/static/css/output.css",
    "watch:css": "tailwindcss -i ./backend/static/css/input.css -o ./backend/static/css/output.css --watch",
    "dev": "concurrently -n \"CSS,APP\" -c \"cyan,green\" \"npm run watch:css\" \"cd backend && ../venv/bin/uvicorn app.main:app --reload\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19"
  }
}