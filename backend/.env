# LeadGen CRM Environment Variables

# Database — leave commented for SQLite (local dev)
# Uncomment for PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/leadgen_crm

# Redis (for Celery broker)
REDIS_URL=redis://localhost:6379/0

# App Settings
APP_NAME=LeadGen CRM
DEBUG=True
SECRET_KEY=change-this-to-a-secure-secret-key
